langlabel <- langlabel[!(langlabel$Name %in% exclusion), ]
langlabel$ID <- 1:nrow(langlabel)
}
# プロット作成
gobj <- ggplot(data = world) + theme_set(theme_bw()) +
geom_sf(fill= "darkolivegreen1") +
geom_point(data = langlabel, aes(x = Longitude, y = Latitude, fill = Color),
size = 4.0, shape = 21) +
geom_text(data = langlabel, aes(x=Longitude, y=Latitude, label=ID),
size = 2.6, color = "darkblue", check_overlap = FALSE) +
xlab("") + ylab("") + ylim(c(-50.5, 75)) +
theme(axis.ticks.x = element_blank(), axis.text.x = element_blank(),
legend.title = element_blank(), legend.position = "none") +
theme(panel.background = element_rect(fill = "aliceblue")) +
scale_fill_identity()
# 保存
ggsave(file = paste0(OUTPUTDIR, "CollabMap_", fileid, ".png"), plot = gobj, width = 8, height = 7)
write.csv(file = paste0(OUTPUTDIR, "langlabel.csv"), langlabel)
# カラーパレット確認用（任意）
png(paste0(OUTPUTDIR, "langfamily-colorcode.png"), width = 500, height = 500)
col2rgb(c("red", "grey50"))
scales::show_col(c("red", "grey50"))
dev.off()
