size = 4) +
geom_text(data = langlabel, aes(x=Longitude, y=Latitude, label=Name),
size = 3, color = "darkblue", vjust=-1) +
scale_color_identity() +  # Color列の色をそのまま使用
theme_bw() +
theme(panel.background = element_rect(fill = "aliceblue"),
axis.title = element_blank(),
axis.text = element_blank(),
axis.ticks = element_blank())
