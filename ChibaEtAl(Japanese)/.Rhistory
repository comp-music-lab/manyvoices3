library(ggplot2)
library(maps)
# 世界地図のデータ取得
world_map <- map_data("world")
# パッケージ読み込み
library(ggplot2)
library(maps)
# 世界地図のデータ取得
world_map <- map_data("world")
# langlabel データ例（適宜読み替え）
# 日本の緯度経度のみ色を変える
langlabel <- read.csv("CollaboratorsPlotData.csv")
# langlabel データ例（適宜読み替え）
# 日本の緯度経度のみ色を変える
langlabel <- read.csv("/Users/gakutochiba/Desktop/manyvoices3-main/data/CollaboratorsPlotData.csv")
# 日本だけ色を赤、それ以外は灰色
langlabel$Color <- ifelse(langlabel$Place == "Japan", "red", "grey50")
# プロット
ggplot() +
geom_polygon(data = world_map, aes(x=long, y=lat, group=group),
